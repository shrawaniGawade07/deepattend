NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_ADMIN_PASSWORD=DeepAttend@Admin

# Optional
NEXT_PUBLIC_ATTENDANCE_THRESHOLD=75

# Resend (https://resend.com) — required for sending attendance report emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxx
# Default sender. Use a verified domain for production; free tier only allows onboarding@resend.dev
RESEND_FROM=DeepAttend <onboarding@resend.dev>
